    {
        "id": "6c24641833ca784c",
        "type": "function",
        "z": "855e9a8019e0e61c",
        "name": "function 6",
        "func": "// 1. รับค่าแรงดันจาก ESP32\nlet voltage = Number(msg.payload.MQ2_Raw);\n\n// 2. ตั้งค่าจุดอ้างอิง (Calibration)\n// ⚠️ สำคัญ: เปลี่ยนเลข 0.45 ด้านล่างนี้ ให้ตรงกับค่า V ที่โชว์บนหน้าจอตอนอากาศสะอาด\nlet V_zero = 0.20; \n\nlet V_max = 3.30;  // บอร์ด ESP32 ปกติรับแรงดันสูงสุดที่ 3.3V ครับ\nlet P_max = 5000;  // ค่า PPM สูงสุดที่ต้องการเทียบบัญญัติไตรยางศ์\n\n// 3. คำนวณค่า PPM แบบ Linear (สมการเส้นตรง)\nlet ppm = ((voltage - V_zero) * P_max) / (V_max - V_zero);\n\n// 4. จัดการค่าที่ติดลบ (ถ้าแรงดันแกว่งลงต่ำกว่า V_zero ให้เซ็ตเป็น 0 เลย)\nif (ppm < 0) {\n    ppm = 0;\n}\n\n// ปัดเศษให้เป็นจำนวนเต็ม\nlet finalPpm = Math.round(ppm);\n\n// 5. ส่งค่าออกไป\nmsg.payload = finalPpm; \nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",

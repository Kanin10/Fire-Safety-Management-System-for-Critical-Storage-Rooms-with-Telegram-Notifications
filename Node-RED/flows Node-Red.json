    {
        "id": "c8298615d5087fd1",
        "type": "function",
        "z": "855e9a8019e0e61c",
        "name": "Control Buzzer & LED",
        "func": "// 1. แปลงค่าให้ชัวร์ว่าเป็นตัวเลข\nvar ppm = Number(msg.payload);\n\nvar threshold_on = 600;\nvar threshold_off = 550;\n\nvar command = \"\";\n\n// 2. เช็คเงื่อนไข\nif (ppm >= threshold_on) {\n    command = \"ON\";\n} else if (ppm < threshold_off) {\n    command = \"OFF\";\n}\n\n// 3. ดึงสถานะล่าสุดที่เคยส่งไป (เพื่อป้องกันการส่งคำสั่งซ้ำรัวๆ)\nvar last_command = context.get('last_command') || \"\";\n\n// 4. ส่งคำสั่งออกไปเฉพาะเมื่อมีคำสั่ง และ \"มีการเปลี่ยนแปลงสถานะจากเดิมจริงๆ\"\nif (command !== \"\" && command !== last_command) {\n    \n    // บันทึกสถานะล่าสุดไว้ใช้เช็คในรอบถัดไป\n    context.set('last_command', command);\n\n    // ขาออกที่ 1: ส่งไป MQTT Out ของ Buzzer (แก้ Topic แล้ว)\n    var msg1 = { \n        topic: \"s6504035610121/switch/gas_alarm_buzzer/command\", \n        payload: command \n    };\n    \n    // ขาออกที่ 2: ส่งไป MQTT Out ของ LED (แก้ Topic แล้ว)\n    var msg2 = { \n        topic: \"s6504035610121/switch/status_led/command\", \n        payload: command \n    };\n    \n    // ส่งข้อความออกไปที่ Output 1 และ Output 2 ตามลำดับ\n    return [msg1, msg2];\n}\n\n// ถ้าค่าอยู่ระหว่าง 550-599 หรือสถานะไม่เปลี่ยน จะไม่ส่งอะไรออกไป\nreturn null;",

    {
        "id": "ef73df6728049dcf",
        "type": "function",
        "z": "855e9a8019e0e61c",
        "name": "Map Nested to Flat",
        "func": "// 1. รับค่าจาก ESP32 (ผ่านโหนด JSON ด้านบน)\nlet d = msg.payload;\n\n// ตรวจสอบว่ามีค่าส่งมาจริงไหม\nif (!d || d.MQ2_Raw === undefined) return null;\n\nlet voltage = d.MQ2_Raw;\nlet V_zero = 0.38;\nlet V_max = 3.10; // ปรับให้ตรงกับ max_value ใน YAML\nlet P_max = 5000;\n\n// 2. คำนวณ PPM\nlet ppm = ((voltage - V_zero) * (P_max) / (V_max - V_zero));\nif (ppm < 0) {\n    ppm = 0;\n}\nlet finalPpm = Math.round(ppm);\n\n// 3. เตรียมส่งให้ ThingsBoard\nmsg.payload = {\n    \"mq2_ppm\": finalPpm,\n    \"mq2_voltage\": voltage,\n    \"led_status\": (d.led_status === \"ON\"),\n    \"timestamp\": d.Time\n};\n\nreturn msg;",

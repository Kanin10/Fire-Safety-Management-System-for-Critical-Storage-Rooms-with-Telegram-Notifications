    {
        "id": "e80e9bc09468f5a2",
        "type": "function",
        "z": "855e9a8019e0e61c",
        "name": "RPC to ESPHome",
        "func": "// 1. แยกแยะข้อมูลจาก ThingsBoard Cloud\nvar requestId = msg.topic.split('/').pop();\nvar method = msg.payload.method;\nvar params = msg.payload.params; // ค่า true/false จาก Dashboard\n\nif (method === \"setLedStatus\" || method === \"setValue\") {\n    \n    // 2. สร้าง Payload สำหรับ ESP32 ให้ตรงกับ YAML เดิม\n    // ส่งเป็น \"ON\" หรือ \"OFF\" ตามที่คำสั่งเดิมรับได้\n    var espMsg = {\n        topic: \"s6504035610121/switch/status_led/command\",\n        payload: params ? \"ON\" : \"OFF\"\n    };\n    \n    // 3. ตอบกลับ ThingsBoard Cloud เพื่อยืนยันคำสั่งสำเร็จ\n    var respMsg = {\n        topic: \"v1/devices/me/rpc/response/\" + requestId,\n        payload: { \"status\": \"success\", \"sent_value\": params ? \"ON\" : \"OFF\" }\n    };\n    \n    return [espMsg, respMsg];\n}\nreturn null;",
        "outputs": 2,
        "timeout": "",
        "noerr": 0,
        "initialize": "",
        "finalize": "",

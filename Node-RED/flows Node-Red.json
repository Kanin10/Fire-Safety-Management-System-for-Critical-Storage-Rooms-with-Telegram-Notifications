    {
        "id": "25bc9aaf2cc63514",
        "type": "function",
        "z": "855e9a8019e0e61c",
        "name": "Check Condition & Limit",
        "func": "var chat_id = \"8568864018\";\nvar cooldown = 10000; // 10 วินาที\n\nvar currentPPM = msg.payload; \nvar lastAlert = flow.get(\"lastAlertTime\") || 0;\nvar now = Date.now();\n\n// เช็คเงื่อนไข: เกิน 1000 และ พ้นช่วง Cooldown แล้ว\nif (currentPPM >= 600 && (now - lastAlert > cooldown)) {\n    flow.set(\"lastAlertTime\", now);\n    msg.payload = {\n        \"chat_id\": chat_id,\n        \"text\": \"🚨 ตรวจพบควัน ก๊าซเกินค่าที่กำหนด! ค่าปัจจุบัน: \" + currentPPM + \" PPM\"\n    };\n    return msg; // ส่งออกไปหาโหนด Send to Telegram\n}\n\nreturn null; // ถ้าไม่เข้าเงื่อนไข ไม่ต้องส่งอะไรออกไป",
